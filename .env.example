# ── API Base URLs ────────────────────────────────────────
# All API base URLs in one place.
# Change these to point to test/staging/prod without touching application code.

# GitLab API — the ONLY place to change the GitLab target
VITE_GITLAB_BASE_URL=https://devcloud.ubs.net/api/v4

# Azure OpenAI — endpoint is also per-deployment in settings, but this is the default
VITE_AZURE_OPENAI_ENDPOINT=

# OpenAI Direct — rarely changes but overridable
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
