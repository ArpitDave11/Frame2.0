{
  "name": "epic-generator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3002",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:headed": "PUPPETEER_HEADLESS=false vitest run --config vitest.e2e.config.ts",
    "test:playwright": "npx playwright test",
    "test:playwright:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.1.0",
    "@azure/msal-react": "^5.0.3",
    "mermaid": "^11.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "fast-check": "^4.5.3",
    "jsdom": "^27.4.0",
    "puppeteer": "^24.36.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.17"
  }
}
