{
  "_meta": {
    "version": "5.0.0",
    "globalDefaults": {
      "statusEmoji": {
        "draft": "📝",
        "in_progress": "🔄",
        "review": "👀",
        "approved": "✅",
        "archived": "📦"
      },
      "markdownFeatures": {
        "collapsibleSections": true,
        "mermaidDiagrams": true,
        "tables": true,
        "taskLists": true,
        "admonitions": false
      },
      "maxTitleLength": 100,
      "defaultPerPage": 20
    }
  },
  "technical_design": {
    "description": "Technical design documents for engineering teams — architecture, APIs, data models, and implementation plans",
    "tone": "precise and technical",
    "storyStyle": "engineering-focused with clear acceptance criteria",
    "architectureFocus": "system architecture and component design",
    "expertRole": "senior software architect",
    "totalWordTarget": { "min": 2000, "max": 5000 },
    "requiredSections": {
      "Objective": { "target": 150, "max": 300, "format": "prose", "hint": "Clear problem statement and goals" },
      "Architecture Overview": { "target": 400, "max": 800, "format": "prose", "diagram": "flowchart", "hint": "High-level system design" },
      "Technical Requirements": { "target": 300, "max": 600, "format": "bullet-list", "hint": "Specific technical constraints and requirements" },
      "Data Model": { "target": 250, "max": 500, "format": "schema-table", "hint": "Entity definitions and relationships" },
      "API Design": { "target": 300, "max": 600, "format": "endpoint-blocks", "hint": "API endpoints, request/response formats" },
      "Implementation Plan": { "target": 300, "max": 600, "format": "phase-table", "hint": "Phased rollout with milestones" },
      "User Stories": { "target": 400, "max": 800, "format": "mixed", "hint": "Detailed user stories with acceptance criteria", "count": { "min": 8, "max": 20 }, "fields": ["title", "description", "acceptance_criteria", "story_points"] }
    },
    "optionalSections": {
      "Non-Functional Requirements": { "target": 200, "max": 400, "format": "table", "hint": "Performance, security, scalability targets" },
      "Sequence Diagrams": { "target": 150, "max": 300, "format": "mermaid-sequence", "diagram": "sequence", "hint": "Key interaction flows" },
      "Error Handling": { "target": 200, "max": 400, "format": "error-table", "hint": "Error codes, recovery strategies" },
      "Migration Strategy": { "target": 200, "max": 400, "format": "numbered-procedure", "hint": "Data migration steps if applicable" },
      "Testing Strategy": { "target": 150, "max": 300, "format": "bullet-list", "hint": "Test approach and coverage targets" },
      "Deployment Plan": { "target": 150, "max": 300, "format": "numbered-procedure", "hint": "Deployment steps and rollback plan" }
    }
  },
